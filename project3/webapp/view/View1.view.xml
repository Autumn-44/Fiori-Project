<mvc:View
    controllerName="project3.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Page
        id="pageDashboard01"
        title="Enterprise Employee Dashboard">

        <content>

            <VBox
                id="mainVBox01"
                width="100%">

                <!-- EMPLOYEE TOOLBAR -->

                <Toolbar
                    id="employeeToolbar01">

                    <Title
                        id="employeeTitle01"
                        text="Employee Records"/>

                    <ToolbarSpacer
                        id="employeeToolbarSpacer01"/>

                    <SearchField
                        id="employeeSearchField01"
                        width="260px"
                        placeholder="Search Employee"
                        search="onEmployeeSearch"/>

                    <Button
                        id="downloadEmployeePdfButton01"
                        text="Employee PDF"
                        icon="sap-icon://pdf-attachment"
                        type="Emphasized"
                        press="onDownloadEmployeePDF"
                        class="sapUiTinyMarginBegin"/>

                    <Button
                        id="downloadCombinedPdfButton01"
                        text="Download All"
                        icon="sap-icon://download"
                        type="Attention"
                        press="onDownloadCombinedPDF"
                        class="sapUiTinyMarginBegin"/>

                    <Button
                        id="addEmployeeButton01"
                        text="Add Employee"
                        icon="sap-icon://add"
                        type="Accept"
                        press="onOpenAddEmployeeDialog"
                        class="sapUiTinyMarginBegin"/>

                </Toolbar>

                <!-- EMPLOYEE TABLE -->

                <ScrollContainer
                    id="employeeScrollContainer01"
                    horizontal="true"
                    vertical="true"
                    width="100%">

                    <Table
                        id="employeeTable01"
                        mode="MultiSelect"
                        width="1700px"
                        items="{/employees}">

                        <columns>

                            <Column id="_IDGenColumn" width="140px">
                                <Text id="_IDGenText" text="Employee ID"/>
                            </Column>

                            <Column id="_IDGenColumn1" width="220px">
                                <Text id="_IDGenText1" text="Employee Name"/>
                            </Column>

                            <Column id="_IDGenColumn2" width="180px">
                                <Text id="_IDGenText2" text="Department"/>
                            </Column>

                            <Column id="_IDGenColumn3" width="220px">
                                <Text id="_IDGenText3" text="Designation"/>
                            </Column>

                            <Column id="_IDGenColumn4" width="180px">
                                <Text id="_IDGenText4" text="Location"/>
                            </Column>

                            <Column id="_IDGenColumn5" width="180px">
                                <Text id="_IDGenText5" text="Salary"/>
                            </Column>

                            <Column id="_IDGenColumn6" width="300px">
                                <Text id="_IDGenText6" text="Email"/>
                            </Column>

                            <Column id="_IDGenColumn7" width="180px">
                                <Text id="_IDGenText7" text="Phone"/>
                            </Column>

                            <Column id="_IDGenColumn8" width="120px">
                                <Text id="_IDGenText8" text="Delete"/>
                            </Column>

                        </columns>

                        <items>

                            <ColumnListItem id="_IDGenColumnListItem">

                                <cells>

                                    <Text id="_IDGenText9" text="{empId}"/>

                                    <ObjectIdentifier id="_IDGenObjectIdentifier"
                                        title="{name}"/>

                                    <Text id="_IDGenText10" text="{department}"/>

                                    <Text id="_IDGenText11" text="{designation}"/>

                                    <Text id="_IDGenText12" text="{location}"/>

                                    <ObjectNumber id="_IDGenObjectNumber"
                                        number="{salary}"
                                        unit="INR"/>

                                    <Text id="_IDGenText13" text="{email}"/>

                                    <Text id="_IDGenText14" text="{phone}"/>

                                    <Button id="_IDGenButton1"
                                        icon="sap-icon://delete"
                                        type="Reject"
                                        press="onDeleteEmployee"/>

                                </cells>

                            </ColumnListItem>

                        </items>

                    </Table>

                </ScrollContainer>

                <!-- PERFORMANCE TOOLBAR -->

                <Toolbar
                    id="performanceToolbar01"
                    class="sapUiLargeMarginTop">

                    <Title
                        id="performanceTitle01"
                        text="Performance Records"/>

                    <ToolbarSpacer id="_IDGenToolbarSpacer"/>

                    <SearchField
                        id="performanceSearchField01"
                        width="260px"
                        placeholder="Search Performance"
                        search="onPerformanceSearch"/>

                    <Button
                        id="downloadPerformancePdfButton01"
                        text="Performance PDF"
                        icon="sap-icon://pdf-attachment"
                        type="Emphasized"
                        press="onDownloadPerformancePDF"
                        class="sapUiTinyMarginBegin"/>

                    <Button
                        id="addPerformanceButton01"
                        text="Add Performance"
                        icon="sap-icon://add"
                        type="Accept"
                        press="onOpenPerformanceDialog"
                        class="sapUiTinyMarginBegin"/>

                </Toolbar>

                <!-- PERFORMANCE TABLE -->

                <ScrollContainer
                    id="performanceScrollContainer01"
                    horizontal="true"
                    vertical="true"
                    width="100%">

                    <Table
                        id="performanceTable01"
                        width="1700px"
                        items="{/performanceEmployees}">

                        <columns>

                            <Column id="_IDGenColumn9" width="150px">
                                <Text id="_IDGenText15" text="Employee ID"/>
                            </Column>

                            <Column id="_IDGenColumn10" width="220px">
                                <Text id="_IDGenText16" text="Employee Name"/>
                            </Column>

                            <Column id="_IDGenColumn11" width="150px">
                                <Text id="_IDGenText17" text="Score"/>
                            </Column>

                            <Column id="_IDGenColumn12" width="180px">
                                <Text id="_IDGenText18" text="Experience"/>
                            </Column>

                            <Column id="_IDGenColumn13" width="150px">
                                <Text id="_IDGenText19" text="Projects"/>
                            </Column>

                            <Column id="_IDGenColumn14" width="180px">
                                <Text id="_IDGenText20" text="Bonus"/>
                            </Column>

                            <Column id="_IDGenColumn15" width="180px">
                                <Text id="_IDGenText21" text="Attendance"/>
                            </Column>

                            <Column id="_IDGenColumn16" width="200px">
                                <Text id="_IDGenText22" text="Promotion"/>
                            </Column>

                            <Column id="_IDGenColumn17" width="180px">
                                <Text id="_IDGenText23" text="Rating"/>
                            </Column>

                            <Column id="_IDGenColumn18" width="120px">
                                <Text id="_IDGenText24" text="Delete"/>
                            </Column>

                        </columns>

                        <items>

                            <ColumnListItem id="_IDGenColumnListItem1">

                                <cells>

                                    <Text id="_IDGenText25" text="{empId}"/>

                                    <ObjectIdentifier id="_IDGenObjectIdentifier1"
                                        title="{name}"/>

                                    <ObjectStatus id="_IDGenObjectStatus"
                                        text="{score}%"
                                        state="{= ${score} &lt; 50 ? 'Error' : 'Success' }"/>

                                    <Text id="_IDGenText26" text="{experience}"/>

                                    <Text id="_IDGenText27" text="{projects}"/>

                                    <ObjectNumber id="_IDGenObjectNumber1"
                                        number="{bonus}"
                                        unit="INR"/>

                                    <Text id="_IDGenText28" text="{attendance}"/>

                                    <Text id="_IDGenText29" text="{promotion}"/>

                                    <ObjectStatus id="_IDGenObjectStatus1"
                                        text="{rating}"
                                        state="{= ${score} &lt; 50 ? 'Error' : 'Success' }"/>

                                    <Button id="_IDGenButton2"
                                        icon="sap-icon://delete"
                                        type="Reject"
                                        press="onDeletePerformance"/>

                                </cells>

                            </ColumnListItem>

                        </items>

                    </Table>

                </ScrollContainer>

            </VBox>

        </content>

    </Page>

</mvc:View>