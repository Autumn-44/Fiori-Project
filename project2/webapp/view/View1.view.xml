<mvc:View
    controllerName="project2.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core">

    <Page
        id="employeePage"
        title="{i18n>appTitle}"
        backgroundDesign="Solid"
        navButtonPress="onNavBack">

        <content>

            <VBox
                id="mainContainer"
                width="100%"
                alignItems="Center"
                class="sapUiLargeMargin">

                <!-- FORM PANEL -->
                <Panel
                    id="employeePanel"
                    width="85%"
                    backgroundDesign="Translucent"
                    class="sapUiResponsiveMargin">

                    <content>

                      
                        <Title
                            id="titleEmployeeRecord"
                            text="{i18n>titleEmployeeRecord}"
                            level="H1"
                            titleStyle="H1"
                            class="sapUiMediumMarginBottom sapUiMediumMarginTop"/>

                        <!-- DESCRIPTION -->
                        <Text
                            id="textEmployeeDescription"
                            text="{i18n>employeeDescription}"
                            class="sapUiLargeMarginBottom"/>

                        <!-- FORM -->
                        <f:SimpleForm
                            id="employeeForm"
                            editable="true"
			layout="ResponsiveGridLayout"
			labelSpanXL="4"
			labelSpanL="3"
			labelSpanM="4"
			labelSpanS="12"
			adjustLabelSpan="false"
			emptySpanXL="0"
			emptySpanL="4"
			emptySpanM="0"
			emptySpanS="0"
			columnsXL="2"
			columnsL="1"
			columnsM="1">

                            <!-- EMPLOYEE ID -->
                            <Label
                                id="labelEmpId"
                                text="{i18n>employeeId}"
                                design="Bold"/>

                            <Input
                                id="inputEmpId"
                                width="380px"
                                required="true"
                                maxLength="8"
                                
                                liveChange="onEmpIdValidation"
                                class="sapUiSmallMarginBottom"/>

                            <!-- FULL NAME -->
                            <Label
                                id="labelFullName"
                                text="{i18n>fullName}"
                                design="Bold"/>

                            <Input
                                id="inputFullName"
                                width="380px"
                                required="true"
                                liveChange="onNameValidation"
                                class="sapUiSmallMarginBottom"/>

                            <!-- EMAIL -->
                            <Label
                                id="labelEmail"
                                text="{i18n>emailAddress}"
                                design="Bold"/>

                            <Input
                                id="inputEmail"
                                width="380px"
                                type="Email"
                                required="true"
                                
                                class="sapUiSmallMarginBottom"/>

                            <!-- PHONE -->
                            <Label
                                id="labelPhone"
                                text="{i18n>phoneNumber}"
                                design="Bold"/>

                            <Input
                                id="inputPhone"
                                width="380px"
                                type="Tel"
                                maxLength="10"
                                required="true"
                                
                                liveChange="onPhoneValidation"
                                class="sapUiSmallMarginBottom"/>

                            <!-- GENDER -->
                            <Label
                                id="labelGender"
                                text="{i18n>gender}"
                                design="Bold"/>

                            <Select
                                id="selectGender"
                                width="380px"
                                selectedKey="default"
                                forceSelection="false"
                                class="sapUiSmallMarginBottom">

                                <items>

                                    <core:Item
                                        id="genderDefault"
                                        key="default"
                                        text="Select Gender"/>

                                    <core:Item
                                        id="genderMale"
                                        key="Male"
                                        text="{i18n>male}"/>

                                    <core:Item
                                        id="genderFemale"
                                        key="Female"
                                        text="{i18n>female}"/>

                                    <core:Item
                                        id="genderOther"
                                        key="Other"
                                        text="{i18n>other}"/>

                                </items>

                            </Select>

                            <!-- DEPARTMENT -->
                            <Label
                                id="labelDepartment"
                                text="{i18n>department}"
                                design="Bold"/>

                            <Select
                                id="selectDepartment"
                                width="380px"
                                selectedKey="default"
                                forceSelection="false"
                                class="sapUiSmallMarginBottom">

                                <items>

                                    <core:Item
                                        id="departmentDefault"
                                        key="default"
                                        text="Select Department"/>

                                    <core:Item
                                        id="deptIT"
                                        key="IT"
                                        text="{i18n>it}"/>

                                    <core:Item
                                        id="deptHR"
                                        key="HR"
                                        text="{i18n>hr}"/>

                                    <core:Item
                                        id="deptFinance"
                                        key="Finance"
                                        text="{i18n>finance}"/>

                                    <core:Item
                                        id="deptMarketing"
                                        key="Marketing"
                                        text="{i18n>marketing}"/>

                                    <core:Item
                                        id="deptSales"
                                        key="Sales"
                                        text="{i18n>sales}"/>

                                </items>

                            </Select>

                            <!-- DESIGNATION -->
                            <Label
                                id="labelDesignation"
                                text="{i18n>designation}"
                                design="Bold"/>

                            <Select
                                id="selectDesignation"
                                width="380px"
                                selectedKey="default"
                                forceSelection="false"
                                class="sapUiSmallMarginBottom">

                                <items>

                                    <core:Item
                                        id="designationDefault"
                                        key="default"
                                        text="Select Designation"/>

                                    <core:Item
                                        id="designationDeveloper"
                                        key="Software Engineer"
                                        text="Software Engineer"/>

                                    <core:Item
                                        id="designationManager"
                                        key="Manager"
                                        text="Manager"/>

                                    <core:Item
                                        id="designationAnalyst"
                                        key="Analyst"
                                        text="Analyst"/>

                                    <core:Item
                                        id="designationConsultant"
                                        key="Consultant"
                                        text="Consultant"/>

                                </items>

                            </Select>

                            <!-- SALARY -->
                            <Label
                                id="labelSalary"
                                text="{i18n>annualSalary}"
                                design="Bold"/>

                            <Input
                                id="inputSalary"
                                width="380px"
                                type="Number"
                                required="true"
                               
                                class="sapUiSmallMarginBottom"/>

                            <!-- JOINING DATE -->
                            <Label
                                id="labelJoiningDate"
                                text="{i18n>joiningDate}"
                                design="Bold"/>

                            <DatePicker
                                id="dateJoining"
                                width="380px"
                                displayFormat="dd/MM/yyyy"
                                valueFormat="yyyy-MM-dd"
                                class="sapUiSmallMarginBottom"/>

                            <!-- EMPLOYEE STATUS -->
                            <Label
                                id="labelStatus"
                                text="{i18n>employeeStatus}"
                                design="Bold"/>

                            <Select
                                id="selectStatus"
                                width="380px"
                                selectedKey="default"
                                forceSelection="false"
                                class="sapUiSmallMarginBottom">

                                <items>

                                    <core:Item
                                        id="statusDefault"
                                        key="default"
                                        text="Select Status"/>

                                    <core:Item
                                        id="statusActive"
                                        key="Active"
                                        text="{i18n>active}"/>

                                    <core:Item
                                        id="statusInactive"
                                        key="Inactive"
                                        text="{i18n>inactive}"/>

                                    <core:Item
                                        id="statusLeave"
                                        key="Leave"
                                        text="{i18n>leave}"/>

                                </items>

                            </Select>

                            <!-- LOCATION -->
                            <Label
                                id="labelLocation"
                                text="{i18n>workLocation}"
                                design="Bold"/>

                            <Input
                                id="inputLocation"
                                width="380px"
                                placeholder="Enter the city of work location"
                                class="sapUiSmallMarginBottom"/>

                            <!-- ADDRESS -->
                            <Label
                                id="labelAddress"
                                text="{i18n>address}"
                                design="Bold"/>

                            <TextArea
                                id="inputAddress"
                                width="380px"
                                rows="3"
                                placeholder="Enter Full Address"
                                class="sapUiSmallMarginBottom"/>

                            <!-- SKILLS -->
                            <Label
                                id="labelSkills"
                                text="{i18n>skills}"
                                design="Bold"/>

                            <Input
                                id="inputSkills"
                                width="380px"
                                placeholder="Java, SAPUI5, SQL"
                                class="sapUiSmallMarginBottom"/>

                            <!-- EXPERIENCE -->
                            <Label
                                id="labelExperience"
                                text="{i18n>experience}"
                                design="Bold"/>

                            <Input
                                id="inputExperience"
                                width="380px"
                                type="Number"
                                maxLength="2"
                                placeholder=""
                                class="sapUiSmallMarginBottom"/>

                        </f:SimpleForm>

                        <!-- SUBMIT BUTTON -->
                        <HBox
                            id="buttonContainer"
                            justifyContent="End"
                            class="sapUiLargeMarginTop sapUiLargeMarginBottom">

                            <Button
                                id="buttonSaveEmployee"
                                text="{i18n>submitForm}"
                                type="Emphasized"
                                width="200px"
                                icon="sap-icon://accept"
                                press="onSubmit"/>

                        </HBox>

                    </content>

                </Panel>

                <!-- THANK YOU SECTION -->
                <VBox
                    id="thankYouContainer"
                    visible="false"
                    alignItems="Center"
                    justifyContent="Center"
                    width="100%"
                    class="sapUiHugeMarginTop">

                    <Title
                        id="thankYouTitle"
                        text="{i18n>thankYou}"
                        level="H1"
                        titleStyle="H1"/>

                    <Text
                        id="thankYouText"
                        text="{i18n>thankYouText}"
                        class="sapUiLargeMarginTop sapUiLargeMarginBottom"/>

                    <!-- DETAILS PANEL -->
                    <Panel
                        id="submittedDetailsPanel"
                        width="900px"
                        backgroundDesign="Translucent">

                        <content>

                            <VBox
                                id="submittedDetailsVBox"
                                width="100%"
                                class="sapUiLargeMargin">

                                <Text
                                    id="submittedEmpId"
                                    class="sapUiSmallMarginBottom"/>

                                <Text
                                    id="submittedName"
                                    class="sapUiSmallMarginBottom"/>

                                <Text
                                    id="submittedEmail"
                                    class="sapUiSmallMarginBottom"/>

                                <Text
                                    id="submittedPhone"
                                    class="sapUiSmallMarginBottom"/>

                                <Text
                                    id="submittedDepartment"
                                    class="sapUiSmallMarginBottom"/>

                                <Text
                                    id="submittedDesignation"
                                    class="sapUiSmallMarginBottom"/>

                                <Text
                                    id="submittedSalary"
                                    class="sapUiSmallMarginBottom"/>

                                <Text
                                    id="submittedLocation"
                                    class="sapUiSmallMarginBottom"/>

                            </VBox>

                        </content>

                    </Panel>

                    <!-- FILL AGAIN BUTTON -->
                    <Button
                        id="buttonFillAgain"
                        text="Fill One More Time"
                        type="Accept"
                        width="250px"
                        visible="false"
                        class="sapUiLargeMarginTop"
                        icon="sap-icon://refresh"
                        press="onFillAgain"/>

                </VBox>

            </VBox>

        </content>

    </Page>

</mvc:View>