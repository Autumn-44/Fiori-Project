<mvc:View
    controllerName="project1.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core">

    <Page title="Employee Management">

        <content>

            <VBox class="sapUiMediumMargin">

                <Title
                    text="Employee Record"
                    level="H2"
                    class="sapUiSmallMarginBottom"/>

                <f:SimpleForm
                    editable="true"
                    layout="ResponsiveGridLayout"
                    columnsXL="2"
                    columnsL="2"
                    columnsM="2">

                    <Label text="Employee ID"/>
                    <Input
                        id="empId"
                        width="250px"
                        placeholder="EMP001"
                        class="sapUiSmallMarginBottom"/>

                    <Label text="Full Name"/>
                    <Input
                        id="nameInput"
                        width="250px"
                        placeholder="Enter Name"
                        class="sapUiSmallMarginBottom"/>

                    <Label text="Email"/>
                    <Input
                        id="emailInput"
                        width="250px"
                        placeholder="Enter Email"
                        class="sapUiSmallMarginBottom"/>

                    <Label text="Department"/>
                    <Select
                        id="departmentSelect"
                        width="250px"
                        class="sapUiSmallMarginBottom">

                        <items>
                            <core:Item key="IT" text="IT"/>
                            <core:Item key="HR" text="HR"/>
                            <core:Item key="Finance" text="Finance"/>
                        </items>

                    </Select>

                </f:SimpleForm>

                <HBox class="sapUiLargeMarginTop">

                    <Button
                        text="Submit"
                        type="Emphasized"
                        press="onSubmit"/>

                    <Button
                        text="Clear"
                        press="onClear"
                        class="sapUiTinyMarginBegin"/>

                </HBox>

            </VBox>

        </content>

    </Page>

</mvc:View>