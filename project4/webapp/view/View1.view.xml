<mvc:View
    controllerName="project4.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">

    <Page
        id="mainPage01"
        title="Employee List">

        <content>

            <VBox
                id="mainVBox01"
                class="sapUiLargeMargin">

                <SearchField
                    id="employeeSearchField01"
                    width="100%"
                    placeholder="Search by Employee ID, Name or Department"
                    search="onSearchEmployee"/>

                <List
                    id="employeeList01"
                    items="{/employees}"
                    itemPress="onItemPress"
                    class="sapUiMediumMarginTop">

                    <StandardListItem
                        id="employeeListItem01"
                        title="{name}"
                        description="{department}"
                        info="{empId}"
                        type="Navigation"/>

                </List>

            </VBox>

        </content>

    </Page>

</mvc:View>