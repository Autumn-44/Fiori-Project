{
  "_version": "1.65.0",

  "sap.app": {
    "id": "project4",
    "type": "application",
    "title": "Routing Application"
  },

  "sap.ui": {
    "technology": "UI5",
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },

  "sap.ui5": {

    "rootView": {
      "viewName": "project4.view.App",
      "type": "XML",
      "async": true,
      "id": "app"
    },

    "dependencies": {
      "minUI5Version": "1.120.0",
      "libs": {
        "sap.m": {}
      }
    },

    "routing": {

      "config": {

        "routerClass": "sap.m.routing.Router",
        "viewType": "XML",
        "viewPath": "project4.view",
        "controlId": "app",
        "controlAggregation": "pages",
        "async": true
      },

      "routes": [

        {
          "name": "RouteView1",
          "pattern": "",
          "target": "TargetView1"
        },

        {
          "name": "RouteView2",
          "pattern": "detail/{empId}",
          "target": "TargetView2"
        }

      ],

      "targets": {

        "TargetView1": {
          "viewName": "View1"
        },

        "TargetView2": {
          "viewName": "View2"
        }

      }

    }

  }
}