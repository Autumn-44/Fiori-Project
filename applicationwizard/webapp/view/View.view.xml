<mvc:View
    controllerName="applicationwizard.controller.View"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:l="sap.ui.layout"
    xmlns:u="sap.ui.unified"
    xmlns:core="sap.ui.core"
    class="sapUiContentPadding">

    <Page
        id="mainPage01"
        title="Job Application Wizard"
        class="customPage">

        <content>

            <Wizard
                id="applicationWizard01"
                complete="onCompleteWizard">

                <!-- STEP 1 -->

                <WizardStep
                    id="wizardStep01"
                    title="Personal Details"
                    icon="sap-icon://employee">

                    <VBox id="_IDGenVBox" class="sapUiMediumMargin">

                        <Title id="_IDGenTitle"
                            text="Enter Personal Information"
                            level="H3"/>

                        <Label id="_IDGenLabel" text="Full Name"/>

                        <Input
                            id="inputName01"
                            placeholder="Enter Full Name"
                            liveChange="onValidateForm"/>

                        <Label id="_IDGenLabel1"
                            text="Email"
                            class="sapUiSmallMarginTop"/>

                        <Input
                            id="inputEmail01"
                            type="Email"
                            placeholder="Enter Email"
                            liveChange="onValidateForm"/>

                        <Label id="_IDGenLabel2"
                            text="Phone Number"
                            class="sapUiSmallMarginTop"/>

                        <Input
                            id="inputPhone01"
                            type="Tel"
                            placeholder="Enter Phone Number"
                            liveChange="onValidateForm"/>

                        <Label id="_IDGenLabel3"
                            text="Gender"
                            class="sapUiSmallMarginTop"/>

                        <Select
                            id="selectGender01">

                            <items>

                                <core:Item id="_IDGenItem"
                                    key=""
                                    text="Select Gender"/>

                                <core:Item id="_IDGenItem1"
                                    key="Male"
                                    text="Male"/>

                                <core:Item id="_IDGenItem2"
                                    key="Female"
                                    text="Female"/>

                            </items>

                        </Select>

                    </VBox>

                </WizardStep>

                <!-- STEP 2 -->

                <WizardStep
                    id="wizardStep02"
                    title="Education Details"
                    icon="sap-icon://education">

                    <VBox id="_IDGenVBox1" class="sapUiMediumMargin">

                        <Title id="_IDGenTitle1"
                            text="Education Information"
                            level="H3"/>

                        <Label id="_IDGenLabel4" text="Degree"/>

                        <Select
    id="inputYear0">

    <items>

        <core:Item id="_IDGenItem8"
            key=""
            text="Select Graduation Year"/>

        <core:Item id="_IDGenItem9" key="2020" text="2020"/>
        <core:Item id="_IDGenItem10" key="2021" text="2021"/>
        <core:Item id="_IDGenItem11" key="2022" text="2022"/>
        <core:Item id="_IDGenItem12" key="2023" text="2023"/>
        <core:Item id="_IDGenItem13" key="2024" text="2024"/>
        <core:Item id="_IDGenItem14" key="2025" text="2025"/>
        <core:Item id="_IDGenItem15" key="2026" text="2026"/>
        <core:Item id="_IDGenItem16" key="2027" text="2027"/>

    </items>

</Select>
                        <Label id="_IDGenLabel5"
                            text="University"
                            class="sapUiSmallMarginTop"/>

                        <Input
                            id="inputUniversity01"
                            placeholder="Enter University"/>

                        <Label id="_IDGenLabel6"
                            text="CGPA"
                            class="sapUiSmallMarginTop"/>

                        <Input
                            id="inputCgpa01"
                            type="Number"
                            placeholder="Enter CGPA"/>

                        <Label id="_IDGenLabel7"
                            text="Graduation Year"
                            class="sapUiSmallMarginTop"/>

                    </VBox>

                </WizardStep>

                <!-- STEP 3 -->

                <WizardStep
                    id="wizardStep03"
                    title="Skills &amp; Experience"
                    icon="sap-icon://developer-settings">

                    <VBox id="_IDGenVBox2" class="sapUiMediumMargin">

                        <Title id="_IDGenTitle2"
                            text="Skills &amp; Experience"
                            level="H3"/>

                        <Label id="_IDGenLabel8" text="Skills"/>

                        <TextArea
                            id="inputSkills01"
                            rows="4"
                            placeholder="Enter Skills"/>

                        <Label id="_IDGenLabel9"
                            text="Experience"
                            class="sapUiSmallMarginTop"/>

                        <Select
                            id="selectExperience01">

                            <items>

                                <core:Item id="_IDGenItem3"
                                    key=""
                                    text="Select Experience"/>

                                <core:Item id="_IDGenItem4"
                                    key="Fresher"
                                    text="Fresher"/>

                                <core:Item id="_IDGenItem5"
                                    key="1-2 Years"
                                    text="1-2 Years"/>

                                <core:Item id="_IDGenItem6"
                                    key="3-5 Years"
                                    text="3-5 Years"/>

                            </items>

                        </Select>

                    </VBox>

                </WizardStep>

                <!-- STEP 4 -->

                <WizardStep
                    id="wizardStep04"
                    title="Job Preferences"
                    icon="sap-icon://briefcase">

                    <VBox id="_IDGenVBox3" class="sapUiMediumMargin">

                        <Title id="_IDGenTitle3"
                            text="Job Preferences"
                            level="H3"/>

                        <Label id="_IDGenLabel10" text="Preferred Role"/>

                        <Input
                            id="inputRole01"
                            placeholder="Enter Preferred Role"/>

                        <Label id="_IDGenLabel11"
                            text="Expected Salary"
                            class="sapUiSmallMarginTop"/>

                        <Input
                            id="inputSalary01"
                            type="Number"
                            placeholder="Enter Expected Salary"/>

                        <Label id="_IDGenLabel12"
                            text="Preferred Location"
                            class="sapUiSmallMarginTop"/>

                        <Select
    id="inputLocation01">

    <items>

        <core:Item id="_IDGenItem17"
            key=""
            text="Select Preferred Location"/>

        <core:Item id="_IDGenItem18"
            key="Hyderabad"
            text="Hyderabad"/>

        <core:Item id="_IDGenItem19"
            key="Bangalore"
            text="Bangalore"/>

        <core:Item id="_IDGenItem20"
            key="Mumbai"
            text="Mumbai"/>

        <core:Item id="_IDGenItem21"
            key="Delhi"
            text="Delhi"/>

        <core:Item id="_IDGenItem22"
            key="Chennai"
            text="Chennai"/>

        <core:Item id="_IDGenItem23"
            key="Pune"
            text="Pune"/>

    </items>

</Select>

                    </VBox>

                </WizardStep>

                <!-- STEP 5 -->

                <WizardStep
                    id="wizardStep05"
                    title="Resume Upload"
                    icon="sap-icon://upload">

                    <VBox id="_IDGenVBox4" class="sapUiMediumMargin">

                        <Title id="_IDGenTitle4"
                            text="Upload Resume"
                            level="H3"/>

                        <u:FileUploader
                            id="resumeUploader01"
                            width="400px"
                            placeholder="Upload Resume"
                            fileType="pdf,doc,docx"/>

                    </VBox>

                </WizardStep>

                <!-- STEP 6 -->

                <WizardStep
                    id="wizardStep06"
                    title="Review &amp; Submit"
                    icon="sap-icon://accept">

                    <VBox id="_IDGenVBox5" class="sapUiMediumMargin">

                        <Title id="_IDGenTitle5"
                            text="Review Application"
                            level="H3"/>

                        <Panel id="_IDGenPanel"
                            expandable="false"
                            class="sapUiMediumMarginTop">

                            <content>

                                <VBox id="_IDGenVBox6"
                                    class="sapUiMediumMargin">

                                    <!-- PERSONAL DETAILS -->

                                    <Title id="_IDGenTitle6"
                                        text="Personal Details"
                                        level="H4"
                                        class="sapUiSmallMarginBottom"/>

                                    <HBox id="_IDGenHBox"
                                        justifyContent="SpaceBetween"
                                        class="sapUiTinyMarginBottom">

                                        <Text id="_IDGenText1" text="Full Name:"/>
                                        <Text id="_IDGenText2" text="{view>/name}"/>

                                    </HBox>

                                    <HBox id="_IDGenHBox1"
                                        justifyContent="SpaceBetween"
                                        class="sapUiTinyMarginBottom">

                                        <Text id="_IDGenText3" text="Email:"/>
                                        <Text id="_IDGenText4" text="{view>/email}"/>

                                    </HBox>

                                    <HBox id="_IDGenHBox2"
                                        justifyContent="SpaceBetween"
                                        class="sapUiTinyMarginBottom">

                                        <Text id="_IDGenText5" text="Phone Number:"/>
                                        <Text id="_IDGenText6" text="{view>/phone}"/>

                                    </HBox>

                                    <HBox id="_IDGenHBox3"
                                        justifyContent="SpaceBetween"
                                        class="sapUiTinyMarginBottom">

                                        <Text id="_IDGenText7" text="Gender:"/>
                                        <Text id="_IDGenText8" text="{view>/gender}"/>

                                    </HBox>

                                    <!-- EDUCATION -->

                                    <Title id="_IDGenTitle7"
                                        text="Education Details"
                                        level="H4"
                                        class="sapUiMediumMarginTop sapUiSmallMarginBottom"/>

                                    <HBox id="_IDGenHBox4"
                                        justifyContent="SpaceBetween"
                                        class="sapUiTinyMarginBottom">

                                        <Text id="_IDGenText9" text="Degree:"/>
                                        <Text id="_IDGenText10" text="{view>/degree}"/>

                                    </HBox>

                                    <HBox id="_IDGenHBox5"
                                        justifyContent="SpaceBetween"
                                        class="sapUiTinyMarginBottom">

                                        <Text id="_IDGenText11" text="University:"/>
                                        <Text id="_IDGenText12" text="{view>/university}"/>

                                    </HBox>

                                    <HBox id="_IDGenHBox6"
                                        justifyContent="SpaceBetween"
                                        class="sapUiTinyMarginBottom">

                                        <Text id="_IDGenText13" text="CGPA:"/>
                                        <Text id="_IDGenText14" text="{view>/cgpa}"/>

                                    </HBox>

                                    <HBox id="_IDGenHBox7"
                                        justifyContent="SpaceBetween"
                                        class="sapUiTinyMarginBottom">

                                        <Text id="_IDGenText15" text="Graduation Year:"/>
                                        <Text id="_IDGenText16" text="{view>/year}"/>

                                    </HBox>

                                    <!-- EXPERIENCE -->

                                    <Title id="_IDGenTitle8"
                                        text="Skills &amp; Experience"
                                        level="H4"
                                        class="sapUiMediumMarginTop sapUiSmallMarginBottom"/>

                                    <HBox id="_IDGenHBox8"
                                        justifyContent="SpaceBetween"
                                        class="sapUiTinyMarginBottom">

                                        <Text id="_IDGenText17" text="Skills:"/>
                                        <Text id="_IDGenText18" text="{view>/skills}"/>

                                    </HBox>

                                    <HBox id="_IDGenHBox9"
                                        justifyContent="SpaceBetween"
                                        class="sapUiTinyMarginBottom">

                                        <Text id="_IDGenText19" text="Experience:"/>
                                        <Text id="_IDGenText20" text="{view>/experience}"/>

                                    </HBox>

                                    <!-- JOB -->

                                    <Title id="_IDGenTitle9"
                                        text="Job Preferences"
                                        level="H4"
                                        class="sapUiMediumMarginTop sapUiSmallMarginBottom"/>

                                    <HBox id="_IDGenHBox10"
                                        justifyContent="SpaceBetween"
                                        class="sapUiTinyMarginBottom">

                                        <Text id="_IDGenText21" text="Preferred Role:"/>
                                        <Text id="_IDGenText22" text="{view>/role}"/>

                                    </HBox>

                                    <HBox id="_IDGenHBox11"
                                        justifyContent="SpaceBetween"
                                        class="sapUiTinyMarginBottom">

                                        <Text id="_IDGenText23" text="Expected Salary:"/>
                                        <Text id="_IDGenText24" text="{view>/salary}"/>

                                    </HBox>

                                    <HBox id="_IDGenHBox12"
                                        justifyContent="SpaceBetween"
                                        class="sapUiTinyMarginBottom">

                                        <Text id="_IDGenText25" text="Preferred Location:"/>
                                        <Text id="_IDGenText26" text="{view>/location}"/>

                                    </HBox>

                                </VBox>

                            </content>

                        </Panel>

                        <Button
                            id="submitButton01"
                            text="Submit Application"
                            type="Emphasized"
                            icon="sap-icon://accept"
                            press="onSubmitApplication"
                            class="sapUiMediumMarginTop"/>

                    </VBox>

                </WizardStep>

            </Wizard>

        </content>

    </Page>

</mvc:View>